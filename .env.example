# ─────────────────────────────────────────────────────────
# AI Market Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────
APP_NAME="AI Market Intelligence Platform"
APP_VERSION="0.1.0"
DEBUG=true

# Origins that are allowed to call the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/market_intelligence

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs

# ── Scraping ──────────────────────────────────────────────
SCRAPING_TIMEOUT=30     # seconds
MAX_RETRIES=3

# ── File Paths ────────────────────────────────────────────
EXPORTS_DIR=exports
UPLOADS_DIR=uploads

# ── AI & Gemini ───────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Embeddings ────────────────────────────────
# Model will be downloaded automatically on first use (~90MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ──────────────────────────────────
# Directory where ChromaDB persists vector data (no server needed)
CHROMA_DIR=chroma_db

# ── Reports ───────────────────────────────────
REPORTS_DIR=reports
